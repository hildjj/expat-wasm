{
  "name": "expat-wasm",
  "version": "4.0.4",
  "description": "Evented parser based on a WASM-compiled version of expat",
  "main": "lib/index.js",
  "type": "module",
  "types": "types/index.d.ts",
  "files": [
    "lib/*",
    "types/*"
  ],
  "repository": "hildjj/expat-wasm",
  "scripts": {
    "clean": "rimraf docs coverage types lib/expat.d.ts lib/expat.js wasm/libexpat/**/*.wasm",
    "test": "ava",
    "coverage": "c8 npm test",
    "lint": "eslint .",
    "docs": "typedoc",
    "postdocs": "npm run webpack",
    "ts": "tsc",
    "webpack": "cd webpack-demo && npm run build",
    "postwebpack": "copyfiles -V webpack-demo/index.html webpack-demo/dist/* docs/",
    "build": "(cd wasm && ./setup && ./wmak) && npm run ts && npm run docs && npm run lint",
    "ci": "npm run ts && npm run lint && npm run docs && npm run coverage"
  },
  "keywords": [
    "xml",
    "parse",
    "expat",
    "wasm"
  ],
  "author": "Joe Hildebrand <joe-github@cursive.net>",
  "license": "MIT",
  "devDependencies": {
    "@cto.af/eslint-config": "6.2.5",
    "@types/emscripten": "1.41.5",
    "@types/node": "25.5.0",
    "ava": "^7.0.0",
    "copyfiles": "2.4.1",
    "eslint": "10.1.0",
    "rimraf": "6.1.3",
    "superc8": "12.3.1",
    "typedoc": "0.28.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  }
}
